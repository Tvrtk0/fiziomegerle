---
// Self-contained hero illustration: a stylized spine (back-health motif)
// with an olive-branch nod to the brand palette. No external assets.
---

<svg
  class="h-auto w-full"
  viewBox="0 0 480 360"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Ilustracija kralježnice s maslinovom grančicom"
>
  <defs>
    <filter id="hero-shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow
        dx="0"
        dy="4"
        stdDeviation="5"
        flood-color="#3a3c33"
        flood-opacity="0.18"></feDropShadow>
    </filter>
    <radialGradient id="hero-bg" cx="50%" cy="42%" r="60%">
      <stop offset="0%" stop-color="#f3f4ea"></stop>
      <stop offset="100%" stop-color="#e3e5cf"></stop>
    </radialGradient>
  </defs>

  <!-- Soft backdrop -->
  <circle cx="240" cy="188" r="152" fill="url(#hero-bg)"></circle>
  <circle cx="240" cy="188" r="152" fill="none" stroke="#d8dabf" stroke-width="2"></circle>

  <!-- Amber glow marking the lumbar "focus" area -->
  <circle cx="245" cy="249" r="30" fill="#e8a33d" opacity="0.22"></circle>

  <!-- Olive branch, bottom-right -->
  <g stroke="#6b705c" stroke-width="3" fill="none" stroke-linecap="round">
    <path d="M418 336 Q396 300 404 252"></path>
  </g>
  <g fill="#868a5c">
    <path d="M0,0 Q15,-11 30,0 Q15,11 0,0 Z" transform="translate(404 258) rotate(-52)"></path>
    <path d="M0,0 Q15,-11 30,0 Q15,11 0,0 Z" transform="translate(410 292) rotate(38) scale(0.95)"></path>
  </g>
  <g fill="#a1a476">
    <path d="M0,0 Q15,-11 30,0 Q15,11 0,0 Z" transform="translate(402 278) rotate(-142)"></path>
    <path d="M0,0 Q15,-11 30,0 Q15,11 0,0 Z" transform="translate(414 316) rotate(142) scale(0.9)"></path>
  </g>

  <!-- Olive branch, top-left -->
  <g stroke="#6b705c" stroke-width="2.5" fill="none" stroke-linecap="round">
    <path d="M96 96 Q112 118 108 150"></path>
  </g>
  <g fill="#a1a476">
    <path d="M0,0 Q13,-9 26,0 Q13,9 0,0 Z" transform="translate(106 118) rotate(30) scale(0.85)"></path>
    <path d="M0,0 Q13,-9 26,0 Q13,9 0,0 Z" transform="translate(100 104) rotate(-140) scale(0.8)"></path>
  </g>

  <!-- Spine: vertebrae bodies + discs, following a gentle S-curve -->
  <g filter="url(#hero-shadow)">
    <!-- discs (behind bodies) -->
    <g fill="#fbfbf5" stroke="#cdcfa8" stroke-width="1.5">
      <rect x="209.5" y="100" width="72" height="9" rx="4.5"></rect>
      <rect x="204" y="134" width="72" height="9" rx="4.5"></rect>
      <rect x="199.5" y="168" width="72" height="9" rx="4.5"></rect>
      <rect x="199.5" y="202" width="72" height="9" rx="4.5"></rect>
      <!-- highlighted lumbar disc -->
      <rect x="204.5" y="236" width="72" height="10" rx="5" fill="#e8a33d" stroke="#c8862a"></rect>
      <rect x="210.5" y="270" width="72" height="9" rx="4.5"></rect>
    </g>

    <!-- transverse "wings" (behind bodies) -->
    <g fill="#868a5c">
      <rect x="188" y="78" width="22" height="18" rx="9"></rect>
      <rect x="278" y="78" width="22" height="18" rx="9"></rect>
      <rect x="183" y="112" width="22" height="18" rx="9"></rect>
      <rect x="273" y="112" width="22" height="18" rx="9"></rect>
      <rect x="177" y="146" width="22" height="18" rx="9"></rect>
      <rect x="267" y="146" width="22" height="18" rx="9"></rect>
      <rect x="174" y="180" width="22" height="18" rx="9"></rect>
      <rect x="264" y="180" width="22" height="18" rx="9"></rect>
      <rect x="177" y="214" width="22" height="18" rx="9"></rect>
      <rect x="267" y="214" width="22" height="18" rx="9"></rect>
      <rect x="184" y="248" width="22" height="18" rx="9"></rect>
      <rect x="274" y="248" width="22" height="18" rx="9"></rect>
    </g>

    <!-- vertebral bodies -->
    <g fill="#6b705c">
      <rect x="204" y="74" width="88" height="26" rx="13"></rect>
      <rect x="199" y="108" width="88" height="26" rx="13"></rect>
      <rect x="193" y="142" width="88" height="26" rx="13"></rect>
      <rect x="190" y="176" width="88" height="26" rx="13"></rect>
      <rect x="193" y="210" width="88" height="26" rx="13"></rect>
      <rect x="200" y="244" width="88" height="26" rx="13"></rect>
      <rect x="205" y="278" width="88" height="26" rx="13"></rect>
    </g>
  </g>
</svg>
