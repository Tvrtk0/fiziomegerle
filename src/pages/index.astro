---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import QuizApp from '../components/QuizApp.tsx';
// Hero photo: physiotherapist treating a patient's back.
// Source: Pexels (free license, no attribution required). Photo by Krukphoto.com.
import heroPhoto from '../assets/physiotherapist.jpg';
---

<Layout>
  <main class="min-h-screen">
    <!-- Landing / hero -->
    <section
      id="hero"
      class="mx-auto flex min-h-screen max-w-3xl flex-col items-center justify-center px-4 py-12 text-center"
    >
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-olive-500">
        Kviz o bolovima u leđima
      </p>

      <h1 class="text-4xl font-extrabold leading-tight text-olive-800 sm:text-5xl">
        Otkrij koju vrstu boli imaš u leđima
      </h1>

      <p class="mt-4 max-w-xl text-lg text-olive-600">
        Odgovori na nekoliko kratkih pitanja i saznaj radi li se vjerojatno o
        mišićnoj boli ili problemu s diskom.
      </p>

      <!-- Hero photo -->
      <div class="mt-8 w-full max-w-lg">
        <Image
          src={heroPhoto}
          alt="Fizioterapeut tretira pacijenta s bolovima u donjem dijelu leđa"
          widths={[480, 768, 1024]}
          sizes="(max-width: 640px) 92vw, 512px"
          loading="eager"
          class="aspect-[3/2] w-full rounded-3xl object-cover shadow-lg ring-1 ring-olive-200"
        />
      </div>

      <button
        id="start-quiz"
        type="button"
        class="mt-10 rounded-2xl bg-olive-600 px-10 py-4 text-lg font-bold text-white shadow-lg transition-all hover:bg-olive-700 hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-olive-400"
      >
        Započni kviz
      </button>
    </section>

    <!-- Quiz (revealed on start) -->
    <section id="quiz-section" class="hidden min-h-screen">
      <QuizApp client:load />
    </section>
  </main>

  <footer class="border-t border-olive-100 bg-cream py-8 text-center">
    <p class="mb-3 text-lg font-bold text-olive-800">Patrik Megerle</p>
    <a
      href="https://www.instagram.com/patrik_megerle/"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 font-semibold text-olive-700 transition-colors hover:text-olive-900"
      aria-label="Instagram profil @patrik_megerle"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" class="h-6 w-6" aria-hidden="true">
        <path
          d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16Zm0 1.62c-3.15 0-3.5.01-4.74.07-.9.04-1.38.19-1.7.32-.43.16-.74.36-1.06.68-.32.32-.52.63-.68 1.06-.13.32-.28.8-.32 1.7-.06 1.24-.07 1.6-.07 4.74s.01 3.5.07 4.74c.04.9.19 1.38.32 1.7.16.43.36.74.68 1.06.32.32.63.52 1.06.68.32.13.8.28 1.7.32 1.24.06 1.6.07 4.74.07s3.5-.01 4.74-.07c.9-.04 1.38-.19 1.7-.32.43-.16.74-.36 1.06-.68.32-.32.52-.63.68-1.06.13-.32.28-.8.32-1.7.06-1.24.07-1.6.07-4.74s-.01-3.5-.07-4.74c-.04-.9-.19-1.38-.32-1.7a2.1 2.1 0 0 0-.68-1.06 2.1 2.1 0 0 0-1.06-.68c-.32-.13-.8-.28-1.7-.32-1.24-.06-1.6-.07-4.74-.07Zm0 2.76a5.46 5.46 0 1 1 0 10.92 5.46 5.46 0 0 1 0-10.92Zm0 1.62a3.84 3.84 0 1 0 0 7.68 3.84 3.84 0 0 0 0-7.68Zm5.65-2.91a1.28 1.28 0 1 1 0 2.56 1.28 1.28 0 0 1 0-2.56Z"
        ></path>
      </svg>
      <span>@patrik_megerle</span>
    </a>
  </footer>

  <script>
    const startBtn = document.getElementById('start-quiz');
    const hero = document.getElementById('hero');
    const quiz = document.getElementById('quiz-section');

    startBtn?.addEventListener('click', () => {
      hero?.classList.add('hidden');
      quiz?.classList.remove('hidden');
      quiz?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</Layout>
