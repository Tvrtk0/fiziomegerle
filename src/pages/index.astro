---
import Layout from '../layouts/Layout.astro';
import QuizApp from '../components/QuizApp.tsx';
import HeroImage from '../components/HeroImage.astro';
---

<Layout>
  <main class="min-h-screen">
    <!-- Landing / hero -->
    <section
      id="hero"
      class="mx-auto flex min-h-screen max-w-3xl flex-col items-center justify-center px-4 py-12 text-center"
    >
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-olive-500">
        Kviz o bolovima u leđima
      </p>

      <h1 class="text-4xl font-extrabold leading-tight text-olive-800 sm:text-5xl">
        Otkrij koju vrstu boli imaš u leđima
      </h1>

      <p class="mt-4 max-w-xl text-lg text-olive-600">
        Odgovori na nekoliko kratkih pitanja i saznaj radi li se vjerojatno o
        mišićnoj boli ili problemu s diskom.
      </p>

      <!-- Hero illustration -->
      <div class="mt-8 w-full max-w-md">
        <HeroImage />
      </div>

      <button
        id="start-quiz"
        type="button"
        class="mt-10 rounded-2xl bg-olive-600 px-10 py-4 text-lg font-bold text-white shadow-lg transition-all hover:bg-olive-700 hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-olive-400"
      >
        Započni kviz
      </button>
    </section>

    <!-- Quiz (revealed on start) -->
    <section id="quiz-section" class="hidden min-h-screen">
      <QuizApp client:load />
    </section>
  </main>

  <script>
    const startBtn = document.getElementById('start-quiz');
    const hero = document.getElementById('hero');
    const quiz = document.getElementById('quiz-section');

    startBtn?.addEventListener('click', () => {
      hero?.classList.add('hidden');
      quiz?.classList.remove('hidden');
      quiz?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</Layout>
