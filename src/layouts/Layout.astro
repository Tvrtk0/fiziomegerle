---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Otkrij koju vrstu boli imaš u leđima',
  description = 'Interaktivni kviz koji ti pomaže otkriti radi li se o mišićnoj boli ili problemu s diskom.',
} = Astro.props;

// Base-aware URL for public assets (works under the /fiziomegerle/ subpath).
const faviconHref = `${import.meta.env.BASE_URL}/favicon.svg`.replace(
  /\/{2,}/g,
  '/',
);
---

<!doctype html>
<html lang="hr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
